{
  "manifest_version": 2,
  "name": "Toggle Native Tab Bar",
  "version": "0.9.5",
  "description": "Shows or hides the native tab bar",
  "homepage_url": "https://github.com/irvinm/Toggle-Native-Tab-Bar",
  "permissions": [],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_icon": "icon-visible.svg",
    "default_title": "Toggle Native Tab Bar"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "Toggle-Native-Tab_Bar@irvinm.addons.mozilla.org"
    }
  },
  "web_accessible_resources": [
    "*.svg",
    "prism.js",
    "prism.css"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "128": "icon-visible.svg"
  },
  "commands": {
    "toggle-tab-bar": {
      "suggested_key": {
        "default": "Ctrl+Alt+T"
      },
      "description": "Toggle the native tab bar"
    }
  }
}